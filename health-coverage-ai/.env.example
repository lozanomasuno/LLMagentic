# =============================================================
# Health Coverage AI — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================

# Application
APP_NAME=Health Coverage AI
APP_VERSION=1.0.0
ENV=development
DEBUG=true

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:4200

# PostgreSQL
# Para ejecución local: POSTGRES_HOST=localhost
# Para Docker Compose: POSTGRES_HOST=postgres
POSTGRES_USER=health_user
POSTGRES_PASSWORD=health_pass_2024
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=health_coverage

# ChromaDB
# Para ejecución local: CHROMA_HOST=localhost
# Para Docker Compose: CHROMA_HOST=chromadb
CHROMA_HOST=localhost
CHROMA_PORT=8001

# OpenAI — OBLIGATORIO: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MODEL=gpt-4o

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console
